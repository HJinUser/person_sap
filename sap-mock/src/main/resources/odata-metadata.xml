<?xml version="1.0" encoding="utf-8"?>
<edmx:Edmx Version="1.0" xmlns:edmx="http://schemas.microsoft.com/ado/2007/06/edmx"
           xmlns:sap="http://www.sap.com/Protocols/SAPData">
  <edmx:DataServices xmlns:m="http://schemas.microsoft.com/ado/2007/08/dataservices/metadata"
                     m:DataServiceVersion="2.0">
    <Schema Namespace="ZHR_EMP_SRV" xml:lang="ko" sap:schema-version="1"
            xmlns="http://schemas.microsoft.com/ado/2008/09/edm">

      <EntityType Name="Employee" sap:content-version="1">
        <Key><PropertyRef Name="Pernr"/></Key>
        <Property Name="Pernr" Type="Edm.String" Nullable="false" MaxLength="8" sap:label="사번"/>
        <Property Name="Ename" Type="Edm.String" MaxLength="40" sap:label="성명"/>
        <Property Name="Gesch" Type="Edm.String" MaxLength="1" sap:label="성별"/>
        <Property Name="Gbdat" Type="Edm.String" sap:label="생년월일"/>
        <Property Name="Hidat" Type="Edm.String" sap:label="입사일"/>
        <Property Name="Orgeh" Type="Edm.String" MaxLength="8" sap:label="조직단위"/>
        <Property Name="OrgehTxt" Type="Edm.String" MaxLength="40" sap:label="조직단위명"/>
        <Property Name="Plans" Type="Edm.String" MaxLength="8" sap:label="직위"/>
        <Property Name="PlansTxt" Type="Edm.String" MaxLength="40" sap:label="직위명"/>
        <Property Name="Stat2" Type="Edm.String" MaxLength="1" sap:label="재직상태"/>
        <Property Name="Massn" Type="Edm.String" MaxLength="2" sap:label="인사조치유형"/>
        <Property Name="Terdt" Type="Edm.String" sap:label="퇴사일"/>
      </EntityType>

      <EntityType Name="Salary" sap:content-version="1">
        <Key><PropertyRef Name="Id"/></Key>
        <Property Name="Id" Type="Edm.Int64" Nullable="false"/>
        <Property Name="Pernr" Type="Edm.String" MaxLength="8" sap:label="사번"/>
        <Property Name="Begda" Type="Edm.String" sap:label="유효시작일"/>
        <Property Name="Endda" Type="Edm.String" sap:label="유효종료일"/>
        <Property Name="Bet01" Type="Edm.Double" sap:label="월기본급"/>
      </EntityType>

      <EntityType Name="Overtime" sap:content-version="1">
        <Key><PropertyRef Name="Id"/></Key>
        <Property Name="Id" Type="Edm.Int64" Nullable="false"/>
        <Property Name="Pernr" Type="Edm.String" MaxLength="8" sap:label="사번"/>
        <Property Name="Zmonth" Type="Edm.String" MaxLength="7" sap:label="대상월"/>
        <Property Name="Othrs" Type="Edm.Double" sap:label="초과근무시간"/>
      </EntityType>

      <EntityType Name="Absence" sap:content-version="1">
        <Key><PropertyRef Name="Id"/></Key>
        <Property Name="Id" Type="Edm.Int64" Nullable="false"/>
        <Property Name="Pernr" Type="Edm.String" MaxLength="8" sap:label="사번"/>
        <Property Name="Awart" Type="Edm.String" MaxLength="4" sap:label="근태유형"/>
        <Property Name="Begda" Type="Edm.String" sap:label="시작일"/>
        <Property Name="Endda" Type="Edm.String" sap:label="종료일"/>
        <Property Name="Abwtg" Type="Edm.Int32" sap:label="근태일수"/>
      </EntityType>

      <EntityType Name="Appraisal" sap:content-version="1">
        <Key><PropertyRef Name="Id"/></Key>
        <Property Name="Id" Type="Edm.Int64" Nullable="false"/>
        <Property Name="Pernr" Type="Edm.String" MaxLength="8" sap:label="사번"/>
        <Property Name="Zyear" Type="Edm.String" MaxLength="4" sap:label="평가연도"/>
        <Property Name="Score" Type="Edm.Int32" sap:label="평가점수"/>
      </EntityType>

      <EntityContainer Name="ZHR_EMP_SRV_Entities" m:IsDefaultEntityContainer="true">
        <EntitySet Name="EmployeeSet" EntityType="ZHR_EMP_SRV.Employee" sap:content-version="1"/>
        <EntitySet Name="SalarySet" EntityType="ZHR_EMP_SRV.Salary" sap:content-version="1"/>
        <EntitySet Name="OvertimeSet" EntityType="ZHR_EMP_SRV.Overtime" sap:content-version="1"/>
        <EntitySet Name="AbsenceSet" EntityType="ZHR_EMP_SRV.Absence" sap:content-version="1"/>
        <EntitySet Name="AppraisalSet" EntityType="ZHR_EMP_SRV.Appraisal" sap:content-version="1"/>
      </EntityContainer>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
